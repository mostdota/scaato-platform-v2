# =============================================
# SCAATO PLATFORM v2 — Variáveis de Ambiente
# =============================================
# Copie para .env.local e preencha os valores

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_publica
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_secreta

# ASAAS (Pagamentos)
# Sandbox: https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/v3
ASAAS_API_KEY=$aact_SUA_CHAVE_ASAAS
ASAAS_API_URL=https://sandbox.asaas.com/api/v3
ASAAS_WEBHOOK_TOKEN=seu_token_webhook_asaas

# CLICKSIGN (Assinatura de Contratos)
# Sandbox: https://sandbox.clicksign.com/api/v1
# Produção: https://app.clicksign.com/api/v1
CLICKSIGN_API_KEY=sua_access_token_clicksign
CLICKSIGN_API_URL=https://sandbox.clicksign.com/api/v1

# APP
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SCAATO
NODE_ENV=development

# SECURITY
WEBHOOK_SECRET=gere-um-uuid-aleatorio-aqui
